# ============================================================
#  Novel Agent V2 — 环境配置模板（复制为 .env 后填入真实值）
# ============================================================

# ── DeepSeek ──────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── 千问 (Qwen) ───────────────────────────────────────────
QWEN_API_KEY=your_qwen_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ── GLM-5 ─────────────────────────────────────────────────
GLM_API_KEY=your_glm_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5

# ── Kimi (Moonshot) ───────────────────────────────────────
KIMI_API_KEY=your_kimi_key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-32k

# ── Ollama（本地部署，免 API Key）────────────────────────
# 启动: ollama serve  +  ollama pull qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b

# ── 默认模型路由 ──────────────────────────────────────────
# 云端可选值: deepseek | qwen | glm | kimi
# 本地可选值: ollama
# 注意: STRONG_MODEL 建议使用具备推理能力的模型（如 deepseek-reasoner / qwq）
#       Checker 和 RepairAgent 使用此模型，降级会影响事实校验质量
DEFAULT_MODEL=deepseek-chat
DEFAULT_PROVIDER=deepseek
STRONG_MODEL=deepseek-reasoner
JSON_MODEL=deepseek-chat
SEARCH_MODEL=deepseek-chat

# ── MinIO（文本归档，可选）───────────────────────────────
MINIO_ENDPOINT=localhost:9006
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=novel-texts
MINIO_SECURE=false

# ── App ───────────────────────────────────────────────────
LOG_LEVEL=INFO
WEB_PORT=9101
WEB_SECRET_PATH=your_secret_path

# ── 向量搜索 ──────────────────────────────────────────────
# 设为 false 可完全禁用向量检索（跳过 ChromaDB 和 embedding 模型下载）
# 禁用后自动降级为关键词搜索，不影响小说生成核心功能
# 适合快速体验或资源受限环境
VECTOR_SEARCH_ENABLED=true

# Embedding model CUDA device. Empty = use system default (CPU or GPU[0]).
# Example: EMBEDDING_CUDA_DEVICE=1  (force RTX 3080 when RTX 3090 is [0])
EMBEDDING_CUDA_DEVICE=
